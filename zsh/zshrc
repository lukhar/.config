ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=10"
ZSH_AUTOSUGGEST_USE_ASYNC=true

# custom completion files
fpath=($HOME/.config/zsh/completions $fpath)


# fix colors on linux
[ "$HOST" = "piecyk" ] && eval `dircolors ~/.config/.dircolors`

# load aliases
[ -f $HOME/.zsh_aliases ] && source $HOME/.zsh_aliases

export PATH=$HOME/bin:$HOME/.pyenv/bin:$PATH
export NOTES=$HOME/documents/shared/notes
export EDITOR=nvim
export LUA_PATH=/usr/share/awesome/lib

precmd() {
  if [[ -n $PYENV_SHELL && "$PWD" != "$_PRECMD_LAST_PWD" ]]; then
    _PRECMD_LAST_PWD="$PWD"
    _PYENV_CURRENT_VERSION=$(pyenv version-name)
    if [[ $_PYENV_CURRENT_VERSION == system ]]; then
      unset VIRTUAL_ENV
    else
      VIRTUAL_ENV=$(pyenv virtualenv-prefix)/envs/$_PYENV_CURRENT_VERSION
    fi
  fi
}

# must run eagerly so hooks are always registered, even when VIRTUAL_ENV is inherited
eval "$(pyenv virtualenv-init -)"

# pyenv virtualenv-init registers _pyenv_virtualenv_hook in precmd_functions,
# which calls `pyenv sh-activate` (~300ms) on every prompt. Override it to only
# fire when the resolved pyenv version changes (not on every cd).
_pyenv_virtualenv_hook() {
  local ret=$?
  if [[ "$PWD" != "$_PYENV_VENV_LAST_PWD" ]]; then
    _PYENV_VENV_LAST_PWD="$PWD"
    # reuse version already resolved by precmd in this same prompt cycle
    local version="${_PYENV_CURRENT_VERSION:-$(pyenv version-name 2>/dev/null)}"
    if [[ "$version" != "$_PYENV_VENV_LAST_VERSION" ]]; then
      _PYENV_VENV_LAST_VERSION="$version"
      if [ -n "${VIRTUAL_ENV-}" ]; then
        eval "$(pyenv sh-activate --quiet || pyenv sh-deactivate --quiet || true)" || true
      else
        eval "$(pyenv sh-activate --quiet || true)" || true
      fi
    fi
  fi
  return $ret
}

__init_fzf() {
  [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
}

__init_pyenv() {
  # static shims PATH instead of slow eval "$(pyenv init -)"
  [ -d "$HOME/.pyenv/shims" ] && export PATH="$HOME/.pyenv/shims:$PATH"

  # ptpython
  [ -x "$(command -v ptpython)" ] && export PTPYTHON_CONFIG_HOME=$HOME/.config/ptpython
}

__init_goenv() {
  [ -d "$HOME/.goenv/shims" ] && export PATH="$HOME/.goenv/shims:$HOME/.goenv/bin:$PATH"
}

__init_rbenv() {
  [ -d "$HOME/.rbenv/shims" ] && export PATH="$HOME/.rbenv/shims:$PATH"
}

__init_nvm() {
  export NVM_DIR="$HOME/.nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
}

__init_hub() {
  [ -x "$(command -v hub)" ] && alias git=hub
}

__init_bat() {
  # use bat as manpager
  [ -x "$(command -v bat)" ] && export MANPAGER="sh -c 'col -bx | bat -l man -p'"
}

__init_sdk() {
  [ -d $HOME/.sdkman ] && source $HOME/.sdkman/bin/sdkman-init.sh
}

__init_pipx() {
  [ -x "$(command -v pipx)" ] && export PATH=$HOME/bin:$HOME/.local/bin:$PATH
}

__init_docker() {
  if [ -x "$(command -v colima)" ]; then
    export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"
    export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE="/var/run/docker.sock"
    export TESTCONTAINERS_HOST_OVERRIDE=$DOCKER_HOST
    export TESTCONTAINERS_RYUK_DISABLED="true"
  fi
}

__init_funcs=(__init_fzf __init_pyenv __init_bat __init_rbenv __init_nvm __init_hub __init_pipx __init_sdk __init_goenv __init_docker)
__init_total=${#__init_funcs[*]}
__init_index=1

# Triggers an init function
# $1: the init function index to trigger
# $2: the number of seconds to wait before triggering
__run() {
  sleep ${2:0}
  echo $1
}

async_init
async_start_worker zsh

init_callback() {
  if [[ "$1" == "__run" ]]
  then
    # Run the current init function
    eval "$__init_funcs[$3]"

    # Trigger the next init function. This ensures the init
    # functions runs in serial.
    if (( __init_index < __init_total ))
    then
      __init_index=$(( __init_index + 1 ))
      async_job zsh __run $__init_index 0
    fi
  fi
}
async_register_callback zsh init_callback

# Trigger init functions asynchronously to avoid blocking shell startup.
async_job zsh __run 1 0

